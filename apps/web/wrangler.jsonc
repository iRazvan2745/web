{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "web",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "main": "./dist/server/server.js",
  "assets": {
    "directory": "./dist/client",
    "binding": "ASSETS"
  },
  "compatibility_flags": ["nodejs_compat"]
}
