{
  "name": "irazz.lol",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "stripe": "21.1.0-beta.2",
      "zod": "^4.1.13",
      "@types/node": "^22.13.14",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "tailwindcss": "^4.1.18",
      "@orpc/server": "^1.12.2",
      "@orpc/client": "^1.12.2",
      "@orpc/openapi": "^1.12.2",
      "@orpc/zod": "^1.12.2",
      "better-auth": "1.5.5",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "dev:web": "turbo run dev --filter=web",
    "docker:build": "docker build -t irazz-lol .",
    "docker:up": "docker compose up --build",
    "stripe": "stripe listen --forward-to localhost:3001/api/stripe/webhook",
    "db:push": "turbo run db:push --filter=@irazz.lol/db",
    "db:studio": "turbo run db:studio --filter=@irazz.lol/db",
    "db:generate": "turbo run db:generate --filter=@irazz.lol/db",
    "db:migrate": "turbo run db:migrate --filter=@irazz.lol/db",
    "db:start": "turbo run db:start --filter=@irazz.lol/db",
    "db:watch": "turbo run db:watch --filter=@irazz.lol/db",
    "db:stop": "turbo run db:stop --filter=@irazz.lol/db",
    "db:down": "turbo run db:down --filter=@irazz.lol/db",
    "check": "oxlint && oxfmt --write"
  },
  "dependencies": {
    "@irazz.lol/env": "workspace:*",
    "dotenv": "^17.3.1",
    "lenis": "^1.3.21",
    "lucide-react": "^1.7.0",
    "motion": "^12.38.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@irazz.lol/config": "workspace:*",
    "@types/node": "^22.19.15",
    "oxfmt": "^0.26.0",
    "oxlint": "^1.57.0",
    "turbo": "^2.8.20",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.5"
}
